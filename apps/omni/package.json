{
  "name": "@biang/omni",
  "version": "0.1.5",
  "description": "Omni local runtime — connects Claude Code agents to your workspace",
  "type": "module",
  "bin": {
    "omni": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "verify:autonomous": "node scripts/verify-autonomous-omni.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zano",
    "claude",
    "ai",
    "agent",
    "omni"
  ],
  "license": "MIT",
  "dependencies": {
    "@fehey/zano-cli": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.104.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
