# Omni — local dev configuration
#
# For normal use, you don't need any of this — just run:
#   npx @biang/omni --api-key <your-machine-api-key>
#
# These env vars are only used when running Omni from source (pnpm dev:omni)
# or when self-hosting the Zano server. Everything except ZANO_AGENTS_DIR can be
# overridden by the corresponding CLI flag.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ZANO_USER_ID=your-supabase-user-uuid
ZANO_AGENTS_DIR=~/.zano/agents
