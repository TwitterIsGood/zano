{
  "name": "zano",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "pnpm --filter @zano/web dev",
    "dev:bridge": "pnpm --filter @fehey/zano-bridge dev",
    "db:generate": "pnpm --filter @zano/db generate",
    "db:push": "pnpm --filter @zano/db push"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@slock-ai/daemon": "^0.40.2"
  },
  "pnpm": {
    "overrides": {
      "react-notion-avatar>@types/react": "^19",
      "react-notion-avatar>@types/react-dom": "^19"
    }
  }
}
